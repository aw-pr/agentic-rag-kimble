# Budget guards for the experiment scaffold.
#
# Edits take effect on the next tick (no restart). Copy to budget.yaml to
# activate locally; the .example file is the committed default.
#
# Subscription routes only (Claude Max + ChatGPT). These are pacing knobs
# and visibility thresholds, not cost limits — there is no per-token bill
# to cap.

# Soft brake: if a worker spawns more than N nested subagents, the tick
# SIGTERMs it and marks the task `blocked` with reason `runaway-subagents`.
per_task_subagent_cap: 3

# Visibility: Mayor flags "burning fast" if the rolling 24h spawn count
# (workers + verifiers) exceeds this threshold. No automatic action.
daily_spawn_threshold: 50

# Soft brake: Mayor warns when LLM-active time for a running phase passes
# N * expected_llm_hours. Heartbeat pauses spawning for that phase only
# until acknowledged with `ack-overspend <phase>` in the Mayor shell.
phase_overspend_multiplier: 2.0

# Cap on concurrent workers. 3 is comfortable inside both Claude Max and
# Codex rate limits.
max_parallel_workers: 3

# A task is marked `stalled` if its log file's mtime is older than this
# many minutes. Set above the Claude Code subagent 10-min watchdog so the
# subagent's own timeout fires first and writes a final log entry.
worker_stall_minutes: 12

# Informational only — actual heartbeat cadence is set by the cron entry
# installed by scripts/install-experiment-cron.sh.
tick_interval_minutes: 5
