#!/usr/bin/env bash
# Publish guard — pre-commit. Blocks personal/machine data and never-commit
# files from entering the tree. Personal patterns are read from a gitignored
# .publish-guard.local (seeded from .publish-guard.local.example).
# Override once, intentionally: git commit --no-verify
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
staged="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -z "$staged" ] && exit 0

# 1. Strict scanner — runs against the working tree (tracked + untracked,
#    gitignore-aware), exempting only private-tier paths. Catches personal
#    positioning phrases before they can slip through a `git add -A`.
#    Pattern list: .publish-guard-strict.local.
if [ -x "$repo_root/scripts/publish-guard-strict-scan.sh" ]; then
  "$repo_root/scripts/publish-guard-strict-scan.sh"
fi

fail=0

# 2. Never-commit files (regardless of .gitignore state).
while IFS= read -r f; do
  case "$f" in
    .env|.env.*|*.local|op-refs.local.sh|*settings.local.json|state.json|jobs|*/auth.json|*.log)
      [ "$f" = ".env.example" ] && continue
      echo "pre-commit: refusing to commit '$f' (machine-specific / secret)." >&2
      fail=1 ;;
  esac
done <<< "$staged"

# 3. Personal-pattern scan of staged content.
# Exempt paths (private-only by design; excluded from publish squash per
# docs/PUBLISH-WORKFLOW.md + HANDOFF.md):
#   runs/**              scaffold audit trail + build-log retrospectives
#   archive/**           historical agent prompts with personal paths
#   HANDOFF.md           private session-handoff notes
#   RUNBOOK.md           private operator playbook
#   LICENSE              legitimate copyright attribution
# The never-commit list above and the leak guard (step 3) still apply.
local_cfg="$repo_root/.publish-guard.local"
if [ -f "$local_cfg" ]; then
  patterns="$(grep -vE '^\s*(#|$)' "$local_cfg" || true)"
  if [ -n "$patterns" ]; then
    while IFS= read -r f; do
      [ -f "$repo_root/$f" ] || continue
      case "$f" in
        runs/*|archive/*|HANDOFF.md|RUNBOOK.md|LICENSE) continue ;;
        .publish-guard.local.example|.publish-guard-strict.local.example) continue ;;
      esac
      while IFS= read -r pat; do
        [ -z "$pat" ] && continue
        if git show ":$f" 2>/dev/null | grep -nE -- "$pat" >/dev/null 2>&1; then
          echo "pre-commit: '$f' contains a personal pattern (/$pat/)." >&2
          fail=1
        fi
      done <<< "$patterns"
    done <<< "$staged"
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "pre-commit: blocked. Fix the above or, if truly intended, --no-verify." >&2
  exit 1
fi

# 4. Repo-specific extension: chain the auth/secrets leak guard. The three
#    concerns (strict phrases first; path-aware personal patterns above; auth
#    leaks below) are enforced through this one hook so none can regress on
#    commit.
if [ -x "$repo_root/scripts/check-secrets.sh" ]; then
  "$repo_root/scripts/check-secrets.sh"
fi
exit 0
