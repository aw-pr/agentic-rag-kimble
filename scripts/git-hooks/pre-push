#!/usr/bin/env bash
# Publish guard — pre-push. Fail-closed gate for a public mirror.
#
# Per-repo config (git config, local, never committed — keeps org/repo names
# out of the tracked tree):
#   publishguard.publicmatch  Substring of the PUBLIC remote URL (e.g.
#                             "myorg/myrepo"). Unset → this hook is inert.
#   publishguard.sentinel     Env var the sanctioned publish path sets to 1.
#                             Default: PUBLISH_GUARD_OK
#   publishguard.historymode  squash (default) | preserve. Informational here;
#                             affects merge style upstream, not the gate logic.
#                             Surfaced in error messages.
#
# On the public remote: only the default branch (main/master) may be pushed,
# AND that push must arrive via the sanctioned path (sentinel env set) — i.e.
# `git publish`, which backs up to the private remote first. A direct
# `git push <public> dev:main` is blocked so it cannot skip that backup.
# Non-fast-forward pushes to the public default branch are rejected even with
# the sentinel set — that enforces the "PUB/main is immutable" invariant and
# is critical in `preserve` mode where it's tempting to rewrite history.
# Deliberate one-off override: git push --no-verify
remote_name="$1"
remote_url="$2"

# Strict scanner — runs on every push, regardless of remote. Catches
# personal positioning phrases before any push leaves the laptop. Pattern
# list: .publish-guard-strict.local. Deliberate override: --no-verify or
# PUBLISH_GUARD_STRICT_SKIP=1.
repo_root_pp="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$repo_root_pp" ] && [ -x "$repo_root_pp/scripts/publish-guard-strict-scan.sh" ]; then
  "$repo_root_pp/scripts/publish-guard-strict-scan.sh"
fi

pub_match="$(git config --get publishguard.publicmatch || true)"
[ -z "$pub_match" ] && exit 0                 # not configured → nothing to guard
case "$remote_url" in
  *"$pub_match"*) : ;;                         # public — restricted below
  *) exit 0 ;;                                 # private/backup — allow everything
esac

sentinel="$(git config --get publishguard.sentinel || true)"
[ -z "$sentinel" ] && sentinel="PUBLISH_GUARD_OK"
history_mode="$(git config --get publishguard.historymode || true)"
[ -z "$history_mode" ] && history_mode="squash"

# Zero SHA = ref deletion or initial push. Bash 3.2-compatible (no associative).
zero="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    "")
      : ;;
    refs/heads/main|refs/heads/master)
      if [ "${!sentinel:-}" != "1" ]; then
        echo "pre-push: direct publish to PUBLIC remote '$remote_name' blocked." >&2
        echo "          Run 'git publish' — it backs up to the private remote" >&2
        echo "          first, then publishes. Deliberate override: --no-verify." >&2
        exit 1
      fi
      # Block non-fast-forward to public default branch even with the sentinel.
      # Enforces "PUB/main is immutable" (critical in historymode=preserve;
      # always-true in squash where publish is append-only anyway).
      if [ "$remote_sha" != "$zero" ] && [ "$local_sha" != "$zero" ]; then
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
          echo "pre-push: non-fast-forward push to PUBLIC '$remote_ref' blocked." >&2
          echo "          history mode = ${history_mode}. PUB/main is immutable —" >&2
          echo "          published commits must not be rewritten. If this is a" >&2
          echo "          deliberate incident-grade history rewrite, override with" >&2
          echo "          --no-verify and confirm with the user first." >&2
          exit 1
        fi
      fi ;;
    *)
      echo "pre-push: '$remote_ref' blocked on PUBLIC remote '$remote_name'." >&2
      echo "          Only the default branch is public. Override: --no-verify." >&2
      exit 1 ;;
  esac
done
exit 0
